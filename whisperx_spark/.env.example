WHISPER_AUTH_USERNAME=admin
WHISPER_AUTH_PASSWORD=change-me
WHISPERX_MODEL=large-v3
WHISPERX_DEVICE=cuda
WHISPERX_POOL_SIZE=2
WHISPERX_ALIGNMENT_DEVICE=cuda
WHISPERX_GERMAN_ALIGNMENT_MODEL=jonatasgrosman/wav2vec2-large-xlsr-53-german
WHISPERX_ESTIMATED_WORKER_GB=6
WHISPERX_COMPUTE_TYPE=float16
WHISPERX_FLASH_ATTENTION=0
WHISPERX_BEAM_SIZE=5
WHISPERX_BEAM_SIZE_SPEED=2
# Decoding-Robustheit gegen unterschlagene Saetze (Default: konservativer als Whisper-Default)
WHISPERX_NO_SPEECH_THRESHOLD=0.8
WHISPERX_LOG_PROB_THRESHOLD=-2.0
WHISPERX_COMPRESSION_RATIO_THRESHOLD=2.4
WHISPERX_CONDITION_ON_PREVIOUS_TEXT=0
# Auto-Retry, wenn VAD/Decoding nur einen kleinen Teil der Audiodauer abdeckt
WHISPERX_COVERAGE_RETRY=1
WHISPERX_MIN_COVERAGE=0.6
WHISPERX_COVERAGE_MIN_AUDIO_SECONDS=5.0
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
